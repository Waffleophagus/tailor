{
	"name": "web",
	"private": true,
	"version": "0.0.0",
	"packageManager": "pnpm@11.2.2",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:proxy": "vite --host 127.0.0.1",
		"build": "vite build",
		"generate:api": "openapi-ts",
		"generate:guts": "cd .. && go run ./tools/generate-types",
		"generate": "pnpm generate:guts && pnpm generate:api",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json --diagnostic-sources \"js,svelte\" && tsc -p tsconfig.node.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@hey-api/openapi-ts": "^0.97.3",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@tsconfig/svelte": "^5.0.8",
		"@types/d3-force": "^3.0.10",
		"@types/node": "^24.12.3",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.0.12"
	},
	"dependencies": {
		"@hey-api/client-fetch": "^0.13.1",
		"better-result": "^2.9.2",
		"cytoscape": "^3.33.4",
		"d3-force": "^3.0.0",
		"zod": "^4.4.3"
	}
}
