# Copy to .env and fill in your Tailscale API key (Settings → Keys in the admin console).
# Used by Playwright E2E tests to enable ACL editing on the running dev backend.

# Real tailnet:
# TAILSCALE_API_KEY=tskey-api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dev demo tailnet (no Cloud API calls; fully interactive sample fleet + ACL):
TAILSCALE_API_KEY=tskey-api-tailor-dev

# Optional for real keys: tailnet name (e.g. example.com or example.ts.net).
# Dev key ignores this and uses demo.tailor.ts.net.
# TAILOR_TAILNET=example.com

# Optional E2E overrides
# TAILOR_E2E_BASE_URL=http://127.0.0.1:5173
# TAILOR_E2E_PERSPECTIVE=alice@demo.tailor.ts.net
# TAILOR_E2E_ALT_PERSPECTIVE=bob@demo.tailor.ts.net
# TAILOR_E2E_DESTINATION=tag:web
